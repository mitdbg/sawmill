		i_item_desc,
		sc.revenue,
		i_current_price,
		i_wholesale_cost,
		i_brand
	 from store, item,
	     (select ss_store_sk, avg(revenue) as ave
	 	from
	 	    (select  ss_store_sk, ss_item_sk, 
	 		     sum(ss_sales_price) as revenue
