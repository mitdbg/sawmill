	 ,i_item_desc
	 ,s_store_id
	 ,s_store_name
	 ,sum(ss_net_profit) as store_sales_profit
	 ,sum(sr_net_loss) as store_returns_loss
	 ,sum(cs_net_profit) as catalog_sales_profit
	 from
	 store_sales
	 ,store_returns
	 ,catalog_sales
	 ,date_dim d1
	 ,date_dim d2
	 ,date_dim d3
	 ,store
	 ,item
	 where
