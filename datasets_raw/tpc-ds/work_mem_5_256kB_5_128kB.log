	 and     d_moy                   = 3
	 and     ws_bill_addr_sk         = ca_address_sk
	 and     ca_gmt_offset           = -5
	 group by i_manufact_id)
	  select  i_manufact_id ,sum(total_sales) total_sales
	 from  (select * from ss 
