	   and   d_moy  = 11) promotional_sales,
	  (select sum(ss_ext_sales_price) total
	   from  store_sales
	        ,store
	        ,date_dim
	        ,customer
	        ,customer_address
	        ,item
	   where ss_sold_date_sk = d_date_sk
