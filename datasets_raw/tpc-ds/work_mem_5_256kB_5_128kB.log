	select  i_item_id,
	        ca_country,
	        ca_state, 
	        ca_county,
	        avg( cast(cs_quantity as decimal(12,2))) agg1,
	        avg( cast(cs_list_price as decimal(12,2))) agg2,
	        avg( cast(cs_coupon_amt as decimal(12,2))) agg3,
	        avg( cast(cs_sales_price as decimal(12,2))) agg4,
