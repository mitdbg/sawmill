	 and     d_moy                   = 1
	 and     ss_addr_sk              = ca_address_sk
	 and     ca_gmt_offset           = -8 
	 group by i_item_id),
	 cs as (
	 select i_item_id,sum(cs_ext_sales_price) total_sales
	 from
	 	catalog_sales,
	 	date_dim,
	         customer_address,
	         item
	 where
	         i_item_id               in (select
	  i_item_id
	from item
	where i_color in ('orchid','chiffon','lace'))
	 and     cs_item_sk              = i_item_sk
	 and     cs_sold_date_sk         = d_date_sk
	 and     d_year                  = 2000
	 and     d_moy                   = 1
	 and     cs_bill_addr_sk         = ca_address_sk
	 and     ca_gmt_offset           = -8 
	 group by i_item_id),
	 ws as (
	 select i_item_id,sum(ws_ext_sales_price) total_sales
	 from
	 	web_sales,
	 	date_dim,
	         customer_address,
	         item
	 where
