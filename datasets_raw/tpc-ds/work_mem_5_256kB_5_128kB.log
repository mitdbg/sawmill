	  ,sum(ws_ext_ship_cost) as "total shipping cost"
	  ,sum(ws_net_profit) as "total net profit"
	from
	   web_sales ws1
	  ,date_dim
	  ,customer_address
	  ,web_site
	where
	    d_date between '1999-5-01' and 
	           ('1999-5-01'::date + interval '60 days')
