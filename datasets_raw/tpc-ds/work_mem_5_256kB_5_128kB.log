	       c_current_cdemo_sk = cd2.cd_demo_sk and
	       c_current_addr_sk = ca_address_sk and
	       c_birth_month in (9,5,12,4,1,10) and
	       d_year = 2001 and
	       ca_state in ('ND','WI','AL'
