	         i_item_id               in (select
	  i_item_id
	from
	 item
	where i_category in ('Children'))
	 and     ws_item_sk              = i_item_sk
	 and     ws_sold_date_sk         = d_date_sk
	 and     d_year                  = 1999
	 and     d_moy                   = 9
	 and     ws_bill_addr_sk         = ca_address_sk
	 and     ca_gmt_offset           = -6
	 group by i_item_id)
	  select   
	  i_item_id
	,sum(total_sales) total_sales
	 from  (select * from ss 
	        union all
	        select * from cs 
	        union all
	        select * from ws) tmp1
	 group by i_item_id
	 order by i_item_id
	      ,total_sales
	 limit 100;
	
	
	
