	       from web_sales 
	           ,date_dim 
	       where d_year = 1999 
	         and d_moy = 1 
	         and ws_sold_date_sk = d_date_sk 
	         and ws_item_sk in (select item_sk from frequent_ss_items)
	         and ws_bill_customer_sk in (select c_customer_sk from best_ss_customer)) x 
	 limit 100;
	with frequent_ss_items as
