					and ('2001-01-12'::date + interval '30 days')
	group by 
		i_item_id
	        ,i_item_desc 
	        ,i_category
	        ,i_class
	        ,i_current_price
	order by 
		i_category
	        ,i_class
	        ,i_item_id
	        ,i_item_desc
	        ,revenueratio
