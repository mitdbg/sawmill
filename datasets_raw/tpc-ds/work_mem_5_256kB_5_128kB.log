	 and     ss_addr_sk              = ca_address_sk
	 and     ca_gmt_offset           = -6 
	 group by i_item_id),
	 cs as (
	 select
	          i_item_id,sum(cs_ext_sales_price) total_sales
	 from
	 	catalog_sales,
	 	date_dim,
	         customer_address,
	         item
	 where
