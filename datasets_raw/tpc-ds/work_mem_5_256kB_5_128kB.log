	          or ss_coupon_amt between 14180 and 14180+1000
	          or ss_wholesale_cost between 38 and 38+20)) B5,
	     (select avg(ss_list_price) B6_LP
	            ,count(ss_list_price) B6_CNT
	            ,count(distinct ss_list_price) B6_CNTD
	      from store_sales
