	 group by i_item_id)
	  select  i_item_id ,sum(total_sales) total_sales
	 from  (select * from ss 
	        union all
	        select * from cs 
	        union all
	        select * from ws) tmp1
	 group by i_item_id
	 order by total_sales,
	          i_item_id
	 limit 100;
	
	
	
