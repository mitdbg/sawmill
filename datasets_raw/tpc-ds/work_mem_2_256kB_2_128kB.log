	  max(cd_dep_count),
	  sum(cd_dep_count),
	  cd_dep_employed_count,
	  count(*) cnt2,
	  avg(cd_dep_employed_count),
	  max(cd_dep_employed_count),
	  sum(cd_dep_employed_count),
