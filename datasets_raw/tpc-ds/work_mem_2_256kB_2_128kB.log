	select  *
	from (select i_category
	            ,i_class
	            ,i_brand
	            ,i_product_name
	            ,d_year
	            ,d_qoy
	            ,d_moy
	            ,s_store_id
	            ,sumsales
	            ,rank() over (partition by i_category order by sumsales desc) rk
	      from (select i_category
	                  ,i_class
	                  ,i_brand
	                  ,i_product_name
	                  ,d_year
	                  ,d_qoy
	                  ,d_moy
	                  ,s_store_id
	                  ,sum(coalesce(ss_sales_price*ss_quantity,0)) sumsales
	            from store_sales
	                ,date_dim
