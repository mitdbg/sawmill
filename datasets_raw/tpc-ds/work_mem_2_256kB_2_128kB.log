	select  *
	from (select i_category
	            ,i_class
	            ,i_brand
	            ,i_product_name
	            ,d_year
	            ,d_qoy
	            ,d_moy
	            ,s_store_id
	            ,sumsales
	            ,rank() over (partition by i_category order by sumsales desc) rk
	      from (select i_category
	                  ,i_class
	                  ,i_brand
	                  ,i_product_name
	                  ,d_year
	                  ,d_qoy
	                  ,d_moy
	                  ,s_store_id
