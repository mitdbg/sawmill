	       cs_bill_cdemo_sk = cd_demo_sk and
	       cs_promo_sk = p_promo_sk and
	       cd_gender = 'F' and 
	       cd_marital_status = 'W' and
	       cd_education_status = 'Primary' and
	       (p_channel_email = 'N' or p_channel_event = 'N') and
	       d_year = 1998 
	 group by i_item_id
	 order by i_item_id
	 limit 100;
	
	
	
