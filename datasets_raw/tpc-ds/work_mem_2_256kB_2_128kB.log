	   and ss_item_sk = i_item_sk
	   and i_manager_id=7
	   and d_moy=11
	   and d_year=1999
	   and ss_customer_sk = c_customer_sk 
	   and c_current_addr_sk = ca_address_sk
	   and substr(ca_zip,1,5) <> substr(s_zip,1,5) 
	   and ss_store_sk = s_store_sk 
	 group by i_brand
	      ,i_brand_id
	      ,i_manufact_id
	      ,i_manufact
	 order by ext_price desc
	         ,i_brand
	         ,i_brand_id
	         ,i_manufact_id
	         ,i_manufact
	limit 100 ;
	
	
	
