2023-11-02 02:19:53.335 EDT [ 654330e1.20b8f 3/5956 ] postgres@tpcds1 LOG:  statement: -- Filename: query040.sql
	
	select  
	   w_state
	  ,i_item_id
	  ,sum(case when (d_date::date < '1998-04-08'::date) 
	 		then cs_sales_price - coalesce(cr_refunded_cash,0) else 0 end) as sales_before
	  ,sum(case when (d_date::date >= '1998-04-08'::date) 
	 		then cs_sales_price - coalesce(cr_refunded_cash,0) else 0 end) as sales_after
	 from
	   catalog_sales left outer join catalog_returns on
	       (cs_order_number = cr_order_number 
	        and cs_item_sk = cr_item_sk)
	  ,warehouse 
	  ,item
	  ,date_dim
	 where
	     i_current_price between 0.99 and 1.49
	 and i_item_sk          = cs_item_sk
	 and cs_warehouse_sk    = w_warehouse_sk 
	 and cs_sold_date_sk    = d_date_sk
	 and d_date between ('1998-04-08'::date - interval '30 days')
	                and ('1998-04-08'::date + interval '30 days') 
	 group by
	    w_state,i_item_id
	 order by w_state,i_item_id
	limit 100;
	
	
	
