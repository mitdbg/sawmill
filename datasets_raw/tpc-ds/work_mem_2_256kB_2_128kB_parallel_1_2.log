2023-11-02 00:28:01.356 EDT [ 6543221a.2085f 3/5834 ] postgres@tpcds1 LOG:  statement: -- Filename: query032.sql
	
	select  sum(cs_ext_discount_amt)  as "excess discount amount" 
	from 
	   catalog_sales 
	   ,item 
	   ,date_dim
	where
	i_manufact_id = 269
	and i_item_sk = cs_item_sk 
	and d_date between '1998-03-18' and 
	        ('1998-03-18'::date + interval '90 days')
	and d_date_sk = cs_sold_date_sk 
	and cs_ext_discount_amt  
	     > ( 
	         select 
	            1.3 * avg(cs_ext_discount_amt) 
	         from 
	            catalog_sales 
	           ,date_dim
	         where 
	              cs_item_sk = i_item_sk 
	          and d_date between '1998-03-18' and
	                             ('1998-03-18'::date + interval '90 days')
	          and d_date_sk = cs_sold_date_sk 
	      ) 
	limit 100;
	
	
	
